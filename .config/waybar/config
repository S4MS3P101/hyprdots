{
  "layer": "top",
  "position": "top",
  "spacing": 5,
  "min-height": 0,
  "margin-right": 10,
  "margin-left": 10,
  "margin-top": 10,
  "reload_style_on_change": true,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-right": ["network", "bluetooth", "pulseaudio", "backlight", "battery", "custom/notification", "clock", "tray"],
  
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
		"1": "ϊ╕Α",
		"2": "ϊ║Ν",
		"3": "ϊ╕Κ",
		"4": "ίδδ",
		"5": "ϊ║Φ",
		"6": "ίΖφ",
		"7": "ϊ╕Δ",
		"8": "ίΖτ",
		"9": "ϊ╣ζ",
		"10": "ίΞΒ",
       },
    "all-outputs": false,
    "persistent-workspaces": {
             "*": 5,
       },
    "sort-by-number": true,
    "active-only": false,
  },

  "hyprland/window": {
    "icon": true,
    "icon-size": 16,
    "max-length": 60,
    "separator": false,
    "tooltip": false,
    "format": "{}"
  },

  "network": {
    "format-wifi": "{icon} {signalStrength}%",
    "format-icons": ["≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
    "format-disconnected": "≤░νψ n/a",
    "format-disabled": "≤░νφ",
    "format-ethernet": "≤░δ│",
    "tooltip-format-wifi": "{essid}: {ipaddr}",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}",
    "interval": 5
  },

  "bluetooth": {
    "format": "{icon}",
    "format-icons": {
	 "enabled": "≤░Γψ",
	 "disabled": "",
	 "connected": "≤░Γ▒",
	 "off": "≤░Γ▓",
    },
    "tooltip-format": "{}",
    "interval": 5
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-icons": {
    "alsa_output.usb-KTMicro_Chu2_DSP_2020-02-20-0000-0000-0000-00.analog-stereo": "≤░ΜΜ",
    "alsa_output.usb-KTMicro_Chu2_DSP_2020-02-20-0000-0000-0000-00.analog-stereo-muted": "≤░θΟ",
    "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
    "default-muted": "Ό╗ρ",
    },
    "scroll-step": 5,
    "on-click-right": "pavucontrol"
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "{icon}≤▒ΡΜ {capacity}%",
    "format-plugged": "{icon}≤▒ΡΜ {capacity}%",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╗", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "interval": 5
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γγ",
      "dnd-notification": "≤░Γδ",
      "dnd-none": "≤░Γδ",
      "inhibited-notification": "≤░Γγ",
      "inhibited-none": "≤░Γγ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░Γδ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A, %B %d %Y}",
    "interval": 10
  },

  "tray": {
    "icon-size": 15
  },

}
